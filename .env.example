# NVIDIA NIM API Key
NVIDIA_NIM_API_KEY=your_api_key_here

# Vision Pipeline Models
NVIDIA_NIM_ROUTER_MODEL=meta/llama-3.2-11b-vision-instruct
NVIDIA_NIM_COSMOS_MODEL=nvidia/cosmos-nemotron-34b
NVIDIA_NIM_OCR_MODEL=nvidia/nv-ocr-v1
NVIDIA_NIM_REASONER_MODEL=nvidia/nemotron-mini-4b-instruct

# Base URL for NVIDIA NIM
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Database Configuration
DATABASE_URL=postgres://user:password@host:port/dbname
