# NVIDIA NIM API Key
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key

# Vision Pipeline Models
NVIDIA_NIM_ROUTER_MODEL=meta/llama-3.2-11b-vision-instruct
NVIDIA_NIM_COSMOS_MODEL=nvidia/cosmos-nemotron-34b
NVIDIA_NIM_OCR_MODEL=nvidia/nv-ocr-v1
NVIDIA_NIM_REASONER_MODEL=meta/llama-3.2-11b-vision-instruct

# Base URL for NVIDIA NIM
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Database Configuration

# Supabase Configuration (Optional for storage/auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Optional: set this in the frontend project only if the API is deployed
# on a different origin. Leave unset when deploying SCARL with the same-origin
# /api function in artifacts/scarl/api/index.ts.
VITE_SCARL_API_URL=https://your-api-project.vercel.app
